# Salin file ini menjadi .env dan isi dengan nilai yang sesuai

# Database Supabase
# Dapatkan dari: Supabase Dashboard > Settings > Database > Connection string
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# NextAuth
# NEXTAUTH_URL = URL aplikasi Anda (localhost saat dev, domain asli saat production)
NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET = string acak, generate dengan: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"

# Salin file ini menjadi .env dan isi dengan nilai yang sesuai

# --- VPS (PostgreSQL lokal di Docker) ---
# Password untuk PostgreSQL container
POSTGRES_PASSWORD="ganti-dengan-password-aman"

# Database URL — pakai hostname "postgres" (service name di docker-compose)
DATABASE_URL="postgresql://postgres:POSTGRES_PASSWORD@postgres:5432/kasir"
DIRECT_URL="postgresql://postgres:POSTGRES_PASSWORD@postgres:5432/kasir"

# NextAuth
# NEXTAUTH_URL = URL aplikasi Anda (localhost saat dev, domain asli saat production)
NEXTAUTH_URL="https://kasir-afitria.my.id"
# Generate NEXTAUTH_SECRET dengan: openssl rand -base64 32
NEXTAUTH_SECRET="ganti-dengan-string-acak-panjang-minimal-32-karakter"

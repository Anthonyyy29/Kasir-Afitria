# Salin file ini menjadi .env dan isi dengan nilai yang sesuai

# Database Supabase — Transaction Pooler (untuk query runtime)
# Dapatkan dari: Supabase Dashboard > Settings > Database > Connection string > Transaction pooler
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (untuk Prisma migrations)
# Dapatkan dari: Supabase Dashboard > Settings > Database > Connection string > Direct connection
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# NextAuth
# NEXTAUTH_URL = URL aplikasi Anda (localhost saat dev, domain asli saat production)
NEXTAUTH_URL="http://localhost:3000"
# Generate NEXTAUTH_SECRET dengan: openssl rand -base64 32
NEXTAUTH_SECRET="ganti-dengan-string-acak-panjang-minimal-32-karakter"
